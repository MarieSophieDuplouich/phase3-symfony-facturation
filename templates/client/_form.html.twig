    {{ form_widget(form.address, {attr: {class: 'w-full border border-gray-200 rounded-lg px-3.5 py-2.5 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-shadow resize-none', rows: 3, placeholder: '12 rue de la Paix, 75001 Paris'}}) }}
