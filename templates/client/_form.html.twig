    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1.5">Téléphone</label>
      {{ form_widget(form.phone, {attr: {class: 'w-full border border-gray-200 rounded-lg px-3.5 py-2.5 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-shadow', placeholder: '+33 6 00 00 00 00'}}) }}
    </div>
  </div>

  <div>
