      {{ form_widget(form.rib, {attr: {class: 'w-full border border-gray-200 rounded-lg px-3.5 py-2.5 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-shadow', placeholder: 'FR76 0000 0000 0000'}}) }}
