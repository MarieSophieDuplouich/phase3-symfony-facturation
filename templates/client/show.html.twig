{% extends 'base.html.twig' %}

{% block title %}Client{% endblock %}

{% block body %}

<div class="min-h-screen flex bg-[#f8fafc]">

    <twig:NavAside/>

    <main class="flex-1 p-8">

        <div class="flex justify-between items-center mb-8">
            <h1 class="text-2xl font-semibold text-gray-900">
                Détails client
            </h1>

            <a href="{{ path('app_client_index') }}"
               class="text-sm text-gray-600 hover:text-gray-900">
                ← Retour
            </a>
        </div>

        <div class="bg-white rounded-lg shadow p-6 max-w-3xl">

            <div class="grid grid-cols-2 gap-4 text-sm">

                <div class="text-gray-500">Nom</div>
                <div>{{ client.name }}</div>

                <div class="text-gray-500">Email</div>
                <div>{{ client.email }}</div>

                <div class="text-gray-500">Téléphone</div>
                <div>{{ client.phone }}</div>

                <div class="text-gray-500">Adresse</div>
                <div>{{ client.address }}</div>

                <div class="text-gray-500">SIRET</div>
                <div>{{ client.siret }}</div>

                <div class="text-gray-500">RIB</div>
                <div>{{ client.rib }}</div>

            </div>

            <div class="flex gap-3 mt-6">

                <a href="{{ path('app_client_edit', {'id': client.id}) }}"
                   class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm">
                    Modifier
                </a>

                {{ include('client/_delete_form.html.twig') }}

            </div>

        </div>

    </main>
</div>

{% endblock %}