{{ form_start(form, {attr: {class: 'flex flex-col gap-5'}}) }}

<div class="flex items-center justify-between mb-7">
    <div class="flex items-center gap-2.5">
      
        <h2 class="text-lg font-semibold text-gray-900">Nouveau produit</h2>
    </div>
    <a href="{{ path('app_product_index') }}" class="p-1.5 rounded-lg text-gray-400 hover:bg-gray-100 hover:text-gray-600 transition-colors">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M15 5L5 15" stroke="#99A1AF" stroke-width="1.66667" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M5 5L15 15" stroke="#99A1AF" stroke-width="1.66667" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
    </a>
</div>

<div>
    <label class="block text-sm font-medium text-gray-600 mb-1.5">Nom du produit</label>
    {{ form_widget(form.name, {attr: {
        class: 'w-full border border-gray-200 rounded-lg px-3.5 py-2.5 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all',
        placeholder: 'Ex : Développement web'
    }}) }}
</div>

<div>
    <label class="block text-sm font-medium text-gray-600 mb-1.5">
        Description
        <span class="text-xs font-normal text-gray-400 bg-gray-100 px-1.5 py-0.5 rounded ml-1">optionnel</span>
    </label>
    {{ form_widget(form.description, {attr: {
        class: 'w-full border border-gray-200 rounded-lg px-3.5 py-2.5 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all resize-none',
        placeholder: 'Décrivez votre produit ou service',
        rows: 3
    }}) }}
</div>

<div class="grid grid-cols-2 gap-4">
    <div>
        <label class="block text-sm font-medium text-gray-600 mb-1.5">Prix HT (€)</label>
        {{ form_widget(form.price, {attr: {
            class: 'w-full border border-gray-200 rounded-lg px-3.5 py-2.5 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all',
            placeholder: '0.00'
        }}) }}
    </div>
    <div>
        <label class="block text-sm font-medium text-gray-600 mb-1.5">Unité</label>
        {{ form_widget(form.unit, {attr: {
            class: 'w-full border border-gray-200 rounded-lg px-3.5 py-2.5 text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all'
        }}) }}
    </div>
</div>

<div class="flex justify-end gap-2 pt-4 mt-1 border-t border-gray-100">
    <a href="{{ path('app_product_index') }}"
       class="inline-flex items-center px-5 py-2.5 text-sm font-medium text-gray-600 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors">
        Annuler
    </a>
    <button type="submit"
            class="inline-flex items-center gap-1.5 px-5 py-2.5 text-sm font-medium text-white bg-[#155DFC] hover:bg-blue-700 active:scale-95 rounded-lg transition-all">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/>
        </svg>
        Enregistrer
    </button>
</div>

{{ form_end(form) }}