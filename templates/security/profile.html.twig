{% extends 'base.html.twig' %}

{% block title %}Profil{% endblock %}

{% block body %}
<div class="min-h-screen flex  gap-6 bg-[#f8fafc]">
    <twig:NavAside />

    <main class="flex-1 p-8 bg-[#f8fafc]">
        <div class="max-w-2xl ">

            <div class="mb-8 px-12 py-12bg-white">
                <h1 class="text-3xl font-semibold text-[#030213]">Mon Profil</h1>
            </div>

            <section class=" bg-white rounded-3xl shadow-sm border border-gray-200 p-8 ">
                {{ form_start(registrationForm, {'attr': {'class': 'grid gap-6'}}) }}
                <div class="grid gap-2">
                    <label for="raison_sociale" class="text-sm font-medium text-[#030213]">Raison
                        Sociale</label>
                    {{form_widget(registrationForm.companyName, {'attr': {'class': 'w-full rounded-2xl border
                    border-gray-200 bg-[#f8fafc] px-4 py-3 text-sm text-[#030213] focus:outline-none focus:ring-2
                    focus:ring-[#030213]/20', 'placeholder': 'Entrez la raison sociale'}})}}

                </div>

                <div class="grid gap-2">
                    <label for="siret" class="text-sm font-medium text-[#030213]">Numéro SIRET
                        (Optionnel)</label>
                    {{form_widget(registrationForm.siret, {'attr': {'class': 'w-full rounded-2xl border
                    border-gray-200 bg-[#f8fafc] px-4 py-3 text-sm text-[#030213] focus:outline-none focus:ring-2
                    focus:ring-[#030213]/20', 'placeholder': '123 456 789 00000'}})}}

                </div>

                <div class="grid gap-2">
                    <label for="iban" class="text-sm font-medium text-[#030213]">IBAN</label>
                    {{ form_widget(registrationForm.iban, {'attr': {'class': 'w-full rounded-2xl border border-gray-200
                    bg-[#f8fafc] px-4 py-3 text-sm text-[#030213] focus:outline-none focus:ring-2
                    focus:ring-[#030213]/20', 'placeholder': 'FR76 1234 5678 9012 3456 7890 123'}}) }}
                    <p class="text-xs text-[#030213]/70">Compte bancaire qui recevra les virements de vos clients.</p>
                </div>

                <div class="grid gap-2">
                    <label for="conditions" class="text-sm font-medium text-[#030213]">Conditions Générales de Vente
                        (CGV)</label>
                    <textarea id="conditions" name="conditions" rows="5"
                        placeholder="Ces conditions apparaîtront en bas de vos factures PDF..."
                        class="w-full rounded-2xl border border-gray-200 bg-[#f8fafc] px-4 py-3 text-sm text-[#030213] focus:outline-none focus:ring-2 focus:ring-[#030213]/20"></textarea>
                </div>

                <button type="submit"
                    class="inline-flex items-center justify-center rounded-2xl bg-[#030213] px-5 py-3 text-sm font-semibold text-white transition hover:bg-[#030213]/90">
                    Enregistrer les modifications
                </button>

                {{ form_end(registrationForm) }}
            </section>
        </div>
    </main>
</div>
{% endblock %}