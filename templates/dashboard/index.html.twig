{% extends 'base.html.twig' %}

{% block title %}Dashboard{% endblock %}

{% block body %}
<div class="min-h-screen flex bg-[#f8fafc]">

    <twig:NavAside/>

    <main class="flex-1 p-8 bg-[#f8fafc]">
        <h1 class="text-2xl font-semibold text-gray-900 mb-8">Dashboard</h1>

        <div class="grid grid-cols-4 gap-4 mb-8">
            <div class="bg-white rounded-2xl border border-gray-200 p-6">
                <div class="w-10 h-10 rounded-full bg-green-100 flex items-center justify-center mb-4">
                    <span class="text-green-600 font-bold text-lg">€</span>
                </div>
                <p class="text-sm text-gray-500 mb-1">Chiffre d'affaires (Payé)</p>
                <p class="text-2xl font-bold text-gray-900">2 250 €</p>
            </div>

            <div class="bg-white rounded-2xl border border-gray-200 p-6">
                <div class="w-10 h-10 rounded-full bg-orange-100 flex items-center justify-center mb-4">
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M12.5 1.66675H5.00004C4.55801 1.66675 4.13409 1.84234 3.82153 2.1549C3.50897 2.46746 3.33337 2.89139 3.33337 3.33341V16.6667C3.33337 17.1088 3.50897 17.5327 3.82153 17.8453C4.13409 18.1578 4.55801 18.3334 5.00004 18.3334H15C15.4421 18.3334 15.866 18.1578 16.1786 17.8453C16.4911 17.5327 16.6667 17.1088 16.6667 16.6667V5.83341L12.5 1.66675Z" stroke="#F97316" stroke-width="1.66667" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </div>
                <p class="text-sm text-gray-500 mb-1">Factures en attente de paiement</p>
                <p class="text-2xl font-bold text-gray-900">1</p>
            </div>

            <div class="bg-white rounded-2xl border border-gray-200 p-6">
                <div class="w-10 h-10 rounded-full bg-blue-100 flex items-center justify-center mb-4">
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M13.3333 17.5V15.8333C13.3333 14.9493 12.9821 14.1014 12.357 13.4763C11.7319 12.8512 10.884 12.5 9.99996 12.5H4.99996C4.1159 12.5 3.26806 12.8512 2.64294 13.4763C2.01782 14.1014 1.66663 14.9493 1.66663 15.8333V17.5" stroke="#3B82F6" stroke-width="1.66667" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M7.49996 9.16667C9.34091 9.16667 10.8333 7.67428 10.8333 5.83333C10.8333 3.99238 9.34091 2.5 7.49996 2.5C5.65901 2.5 4.16663 3.99238 4.16663 5.83333C4.16663 7.67428 5.65901 9.16667 7.49996 9.16667Z" stroke="#3B82F6" stroke-width="1.66667" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </div>
                <p class="text-sm text-gray-500 mb-1">Total Clients</p>
                <p class="text-2xl font-bold text-gray-900">2</p>
            </div>

            <div class="bg-white rounded-2xl border border-gray-200 p-6">
                <div class="w-10 h-10 rounded-full bg-purple-100 flex items-center justify-center mb-4">
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M9.16667 2.5L2.5 6.25V13.75L9.16667 17.5L15.8333 13.75V6.25L9.16667 2.5Z" stroke="#9333EA" stroke-width="1.66667" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M9.16663 17.5V10" stroke="#9333EA" stroke-width="1.66667" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M15.8334 6.25L9.16671 10L2.5 6.25" stroke="#9333EA" stroke-width="1.66667" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </div>
                <p class="text-sm text-gray-500 mb-1">Total Produits</p>
                <p class="text-2xl font-bold text-gray-900">3</p>
            </div>
        </div>

        <div class="bg-white rounded-2xl border border-gray-200 p-6 mb-8">
            <div class="flex justify-between items-center mb-6">
                <h2 class="text-base font-semibold text-gray-900">Chiffre d'affaires mensuel (Factures payées)</h2>
                <select class="border border-gray-200 rounded-lg px-3 py-1.5 text-sm text-gray-600">
                    <option>2023</option>
                    <option>2024</option>
                    <option>2025</option>
                </select>
            </div>
            <div class="flex items-end gap-2 h-48">
                {% set mois = ['Jan', 'Fév', 'Mar', 'Avr', 'Mai', 'Juin', 'Juil', 'Août', 'Sep', 'Oct', 'Nov', 'Déc'] %}
                {% for m in mois %}
                    <div class="flex flex-col items-center flex-1 gap-1">
                        <div class="w-full rounded-t {{ m == 'Mar' ? 'bg-blue-500 h-40' : 'bg-gray-100 h-2' }}"></div>
                        <span class="text-xs text-gray-400">{{ m }}</span>
                    </div>
                {% endfor %}
            </div>
        </div>

        <div class="grid grid-cols-3 gap-4 mb-4">
            <a href="#" class="bg-blue-50 rounded-2xl border border-blue-100 p-6 flex justify-between items-start hover:bg-blue-100 transition">
                <div>
                    <p class="font-semibold text-blue-700 mb-1">Créer une facture</p>
                    <p class="text-sm text-blue-500">Nouvelle prestation</p>
                </div>
                <span class="text-blue-500 text-xl">→</span>
            </a>

            <a href="#" class="bg-white rounded-2xl border border-gray-200 p-6 flex justify-between items-start hover:bg-gray-50 transition">
                <div>
                    <p class="font-semibold text-gray-900 mb-1">Ajouter un client</p>
                    <p class="text-sm text-gray-500">Gérer le répertoire</p>
                </div>
                <span class="text-gray-400 text-xl">→</span>
            </a>

            <a href="#" class="bg-white rounded-2xl border border-gray-200 p-6 flex justify-between items-start hover:bg-gray-50 transition">
                <div>
                    <p class="font-semibold text-gray-900 mb-1">Créer un produit / service</p>
                    <p class="text-sm text-gray-500">Enrichir le catalogue pour rédiger rapidement vos factures</p>
                </div>
                <span class="text-gray-400 text-xl">→</span>
            </a>
        </div>

        <div class="grid grid-cols-3 gap-4">
            <a href="#" class="bg-white rounded-2xl border border-gray-200 p-6 flex justify-between items-start hover:bg-gray-50 transition">
                <div>
                    <p class="font-semibold text-gray-900 mb-1">Relancer tous les clients</p>
                    <p class="text-sm text-gray-500">Envoyer un mail à tous les clients en retard de paiement</p>
                </div>
                <span class="text-gray-400 text-xl">→</span>
            </a>
        </div>
    </main>
</div>
{% endblock %}