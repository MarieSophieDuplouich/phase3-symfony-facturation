<div {{ attributes }}>

    {# Informations générales #}
    <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 mb-4">
        <h2 class="text-base font-semibold text-gray-800 mb-4">Informations Générales</h2>
        <div class="grid grid-cols-2 gap-4">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5">Client</label>
                <div class="flex gap-2">
                    <select data-model="clientId"
                            class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
                        <option value="">Sélectionner un client</option>
                        {% for client in this.clients %}
                            <option value="{{ client.id }}" {{ clientId == client.id ? 'selected' : '' }}>
                                {{ client.name }}
                            </option>
                        {% endfor %}
                    </select>
                    <a href="{{ path('app_client_new') }}"
                       class="flex items-center justify-center w-10 h-10 border border-gray-200 rounded-lg hover:bg-gray-50 text-gray-500">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/>
                        </svg>
                    </a>
                </div>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5">Date de la facture</label>
                <input type="date" data-model="date"
                       value="{{ date }}"
                       class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
        </div>
    </div>

    {# Lignes de la facture #}
    <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 mb-4">
        <h2 class="text-base font-semibold text-gray-800 mb-4">Lignes de la facture</h2>

        <table class="w-full mb-4">
            <thead>
                <tr class="border-b border-gray-100">
                    <th class="text-left text-sm font-semibold text-gray-700 pb-2">Produit / Service</th>
                    <th class="text-right text-sm font-semibold text-gray-700 pb-2 w-20">Qté</th>
                    <th class="text-right text-sm font-semibold text-gray-700 pb-2 w-32">Prix Unitaire</th>
                    <th class="text-right text-sm font-semibold text-gray-700 pb-2 w-32">Total</th>
                    <th class="w-10"></th>
                </tr>
            </thead>
            <tbody>
                {% if lines is empty %}
                    <tr>
                        <td colspan="5" class="py-6 text-center text-sm text-gray-400">Aucune ligne ajoutée</td>
                    </tr>
                {% else %}
                    {% for i, line in lines %}
                        <tr class="border-b border-gray-50">
                            <td class="py-3">
                                <p class="text-sm font-medium text-gray-900">{{ line.name }}</p>
                                <p class="text-xs text-gray-400">{{ line.description }}</p>
                            </td>
                            <td class="py-3 text-right text-sm text-gray-700">{{ line.quantity }}</td>
                            <td class="py-3 text-right text-sm text-gray-700">{{ line.unitPrice|number_format(2) }} €</td>
                            <td class="py-3 text-right text-sm font-semibold text-gray-900">
                                {{ (line.quantity * line.unitPrice)|number_format(2) }} €
                            </td>
                            <td class="py-3 text-center">
                                <button data-action="live#action"
                                        data-live-action-param="removeLine"
                                        data-live-index-param="{{ i }}"
                                        type="button"
                                        class="text-gray-300 hover:text-red-500 transition-colors">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0"/>
                                    </svg>
                                </button>
                            </td>
                        </tr>
                    {% endfor %}
                {% endif %}
            </tbody>
        </table>

        {# Ajout de ligne #}
        <div class="bg-gray-50 rounded-lg p-4 border border-gray-100">
            <div class="grid grid-cols-12 gap-3 items-end">
                <div class="col-span-6">
                    <label class="block text-xs font-medium text-gray-600 mb-1">Sélectionner un produit</label>
                    <select data-model="selectedProductId"
                            class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
                        <option value="">-- Choisir --</option>
                        {% for product in this.products %}
                            <option value="{{ product.id }}" {{ selectedProductId == product.id ? 'selected' : '' }}>
                                {{ product.name }} — {{ product.price|number_format(2) }} €
                            </option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-span-2">
                    <label class="block text-xs font-medium text-gray-600 mb-1">Quantité</label>
                    <input type="number" data-model="quantity" value="{{ quantity }}" min="1"
                           class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 text-right">
                </div>
                <div class="col-span-4">
                    <button data-action="live#action"
                            data-live-action-param="addLine"
                            type="button"
                            class="w-full flex items-center justify-center gap-1.5 bg-gray-700 hover:bg-gray-800 text-white rounded-lg px-3 py-2 text-sm font-medium transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/>
                        </svg>
                        Ajouter
                    </button>
                </div>
            </div>
        </div>

        {# Total #}
        <div class="flex justify-end mt-4 pt-4 border-t border-gray-100">
            <p class="text-base font-semibold text-gray-700">
                Total Facture (TTC) :
                <span class="text-[#155DFC] ml-2">{{ this.total|number_format(2) }} €</span>
            </p>
        </div>
    </div>

    {# Boutons #}
    <div class="flex justify-end gap-3">
        <a href="{{ path('app_invoice_index') }}"
           class="inline-flex items-center px-5 py-2.5 text-sm font-medium text-gray-600 bg-white border border-gray-200 rounded-lg hover:bg-gray-50 transition-colors">
            Annuler
        </a>
        <button data-action="live#action"
                data-live-action-param="save"
                data-live-action-param="draft"
                type="button"
                class="inline-flex items-center px-5 py-2.5 text-sm font-medium text-[#155DFC] bg-white border border-[#155DFC] rounded-lg hover:bg-blue-50 transition-colors">
            Enregistrer en brouillon
        </button>
        <button data-action="live#action"
                data-live-action-param="save"
                data-live-action-param="validate"
                type="button"
                class="inline-flex items-center px-5 py-2.5 text-sm font-medium text-white bg-[#155DFC] hover:bg-blue-700 rounded-lg transition-colors">
            Enregistrer et valider
        </button>
    </div>

</div>